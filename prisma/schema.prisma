generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── AUTENTICACIÓN ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(OPERARIO)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  operario Operario?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  usado     Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

enum Role {
  ADMIN
  OPERARIO
}

// ─── OPERARIOS ────────────────────────────────────────────────────────────────

model Operario {
  id        String   @id @default(cuid())
  userId    String   @unique
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  servicios Servicio[]

  serviciosExterior Servicio[] @relation("ExtOp")
  serviciosSecado   Servicio[] @relation("SecOp")
  serviciosInterior Servicio[] @relation("IntOp")

  cierres       CierreCaja[]
  pagos         PagoOperario[]

  @@map("operarios")
}

// ─── TIPOS DE SERVICIO ────────────────────────────────────────────────────────

model TipoServicio {
  id              String  @id @default(cuid())
  nombre          String
  descripcion     String?
  precio          Float
  duracionMinutos Int     @default(30)
  activo          Boolean @default(true)

  servicios       Servicio[]
  servicioItems   ServicioItem[]
  materiales      MaterialServicio[]

  @@map("tipos_servicio")
}

// ─── VEHÍCULOS ────────────────────────────────────────────────────────────────

model Vehiculo {
  id              String       @id @default(cuid())
  placa           String       @unique
  marca           String
  modelo          String?
  anio            Int?
  color           String?
  tipo            TipoVehiculo @default(SEDAN)
  clienteNombre   String?
  clienteTelefono String?
  clienteEmail    String?
  observaciones   String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  servicios Servicio[]

  @@map("vehiculos")
}

enum TipoVehiculo {
  SEDAN
  SUV
  CAMIONETA
  MOTO
  BUS
  OTRO
}

// ─── SERVICIOS (TURNOS DE LAVADO — LÍNEA ÚNICA) ───────────────────────────────

model Servicio {
  id             String         @id @default(cuid())
  vehiculoId     String
  operarioId     String?
  tipoServicioId String?

  // Etapa en la línea de trabajo
  etapa          EtapaLavado?

  // Quién ejecutó cada etapa
  opExteriorId   String?
  opSecadoId     String?
  opInteriorId   String?

  horaIngreso     DateTime       @default(now())
  horaInicio      DateTime?
  horaSalida      DateTime?
  duracionMinutos Int?

  estado        EstadoServicio @default(EN_ESPERA)
  metodoPago    MetodoPago?
  monto         Float?
  descuento     Float?         @default(0)
  total         Float?
  observaciones String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehiculo     Vehiculo      @relation(fields: [vehiculoId], references: [id])
  operario     Operario?     @relation(fields: [operarioId], references: [id])
  tipoServicio TipoServicio? @relation(fields: [tipoServicioId], references: [id])
  items        ServicioItem[]

  opExterior Operario? @relation("ExtOp", fields: [opExteriorId], references: [id])
  opSecado   Operario? @relation("SecOp", fields: [opSecadoId],   references: [id])
  opInterior Operario? @relation("IntOp", fields: [opInteriorId], references: [id])

  consumos ConsumibleUsado[]

  @@map("servicios")
}

model ServicioItem {
  id             String  @id @default(cuid())
  servicioId     String
  tipoServicioId String
  nombre         String
  precio         Float

  servicio     Servicio     @relation(fields: [servicioId], references: [id], onDelete: Cascade)
  tipoServicio TipoServicio @relation(fields: [tipoServicioId], references: [id])

  @@map("servicio_items")
}

enum EstadoServicio {
  EN_ESPERA
  EN_PROCESO
  POR_COBRAR
  COMPLETADO
  CANCELADO
}

enum EtapaLavado {
  EXTERIOR
  SECADO
  INTERIOR
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  TARJETA
  MERCADOPAGO
  BILLETERA
}

// ─── BODEGA / CONSUMIBLES ─────────────────────────────────────────────────────

model Material {
  id            String   @id @default(cuid())
  nombre        String
  unidad        String   @default("unidades")
  stockTotal    Float    @default(0)
  stockAlerta   Float    @default(5)
  costoUnitario Float    @default(0)
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now())

  configuraciones MaterialServicio[]
  movimientos     MovimientoMaterial[]
  consumos        ConsumibleUsado[]

  @@map("materiales")
}

model MaterialServicio {
  id                  String @id @default(cuid())
  tipoServicioId      String
  materialId          String
  cantidadPorServicio Float  @default(1)

  tipoServicio TipoServicio @relation(fields: [tipoServicioId], references: [id], onDelete: Cascade)
  material     Material     @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([tipoServicioId, materialId])
  @@map("material_servicio")
}

model MovimientoMaterial {
  id         String         @id @default(cuid())
  materialId String
  cantidad   Float
  tipo       TipoMovimiento
  nota       String?
  createdAt  DateTime       @default(now())

  material Material @relation(fields: [materialId], references: [id])

  @@map("movimientos_material")
}

model ConsumibleUsado {
  id         String @id @default(cuid())
  servicioId String
  materialId String
  cantidad   Float
  nombre     String
  unidad     String

  servicio Servicio @relation(fields: [servicioId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id])

  @@map("consumibles_usados")
}

enum TipoMovimiento {
  ENTRADA
  SALIDA
}

// ─── PAGOS A OPERARIOS ────────────────────────────────────────────────────────

model PagoOperario {
  id         String   @id @default(cuid())
  operarioId String
  monto      Float
  fecha      DateTime @default(now())
  nota       String?
  createdAt  DateTime @default(now())

  operario Operario @relation(fields: [operarioId], references: [id])

  @@map("pagos_operarios")
}

// ─── PROMOCIONES ──────────────────────────────────────────────────────────────

model Promocion {
  id            String        @id @default(cuid())
  nombre        String
  descripcion   String?
  tipoDescuento TipoDescuento @default(PORCENTAJE)
  valor         Float
  fechaInicio   DateTime
  fechaFin      DateTime
  activa        Boolean       @default(true)
  createdAt     DateTime      @default(now())

  @@map("promociones")
}

enum TipoDescuento {
  PORCENTAJE
  VALOR_FIJO
}

// ─── CIERRE DE CAJA ───────────────────────────────────────────────────────────

model CierreCaja {
  id                 String   @id @default(cuid())
  nombre             String   @default("Turno")
  periodoDesde       DateTime
  periodoHasta       DateTime
  operarioId         String?
  totalEfectivo      Float    @default(0)
  totalTransferencia Float    @default(0)
  totalTarjeta       Float    @default(0)
  totalIngresos      Float    @default(0)
  totalVehiculos     Int      @default(0)
  totalServicios     Int      @default(0)
  notas              String?
  createdAt          DateTime @default(now())

  operario Operario? @relation(fields: [operarioId], references: [id])

  @@map("cierres_caja")
}

// ─── AUDITORÍA ────────────────────────────────────────────────────────────────

model AuditEntry {
  id           String   @id @default(cuid())
  entidadTipo  String
  entidadId    String
  campo        String
  valorAntes   String?
  valorDespues String?
  userId       String
  userName     String
  createdAt    DateTime @default(now())

  @@index([entidadId])
  @@map("audit_entries")
}

// ─── LICENCIA / GOBERNANZA ───────────────────────────────────────────────────

model Licencia {
  id               String       @id @default("singleton")
  plan             PlanLicencia @default(PRO)
  fechaVencimiento DateTime
  suspendida       Boolean      @default(false)
  notasAdmin       String?
  updatedAt        DateTime     @updatedAt

  pagos PagoLicencia[]

  @@map("licencia")
}

enum PlanLicencia {
  BASICO
  PRO
  ENTERPRISE
}

model PagoLicencia {
  id            String   @id @default(cuid())
  licenciaId    String
  monto         Float
  moneda        String   @default("COP")
  periodoInicio DateTime
  periodoFin    DateTime
  fechaPago     DateTime @default(now())
  notas         String?

  licencia Licencia @relation(fields: [licenciaId], references: [id])

  @@map("pagos_licencia")
}
